PORT=4000
FRONTEND_URL=http://localhost
DATABASE_CONNECTION_STRING=postgres://postgres:postgres@postgres:5432/appdb
API_VERSION=v1

# OpenRouter / LLM summary
OPEN_ROUTER_KEY=your_openrouter_api_key
SUMMARY_MODEL=openai/gpt-4o-mini
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Deepgram transcription
DEEPGRAM_API_KEY=your_deepgram_api_key
TRANSCRIPTION_MODEL=nova-3

# S3 (LocalStack in docker-compose)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AUDIO_BUCKET_NAME=my-bucket
AUDIO_FILE_PATH=notes
AWS_ENDPOINT_URL=http://localstack:4566
# Optional: public S3 endpoint used when returning signed URLs to the browser.
AWS_PUBLIC_ENDPOINT_URL=http://localhost:4566